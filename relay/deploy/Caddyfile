# cute.tech relay — Caddy config
#
# Caddy holds a single wildcard certificate for *.cute.tech, obtained via a
# DNS-01 challenge through Cloudflare (the zone's DNS host) — no per-subdomain
# on-demand issuance, so there's no Let's Encrypt rate-limit exposure from
# subdomain scanners and no need to gate issuance through the relay's /known
# endpoint.
#
# Requires CF_API_TOKEN (scoped to Zone:DNS:Edit for the cute.tech zone) in
# the caddy service environment — see /etc/caddy/cloudflare.env, wired in via
# the caddy.service.d/cloudflare.conf systemd drop-in (both created by
# deploy/setup.sh).

*.cute.tech {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
	reverse_proxy localhost:8080
}

# Plain HTTP: redirect to HTTPS.
http:// {
	redir https://{host}{uri} permanent
}
