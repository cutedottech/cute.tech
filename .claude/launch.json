{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "python3 -m http.server ${PORT:-8000}"],
      "port": 8000,
      "autoPort": true
    },
    {
      "name": "relay",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "relay", "run", "dev"],
      "port": 8080
    }
  ]
}
